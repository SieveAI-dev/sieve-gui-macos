# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# Swift 官方默认 4 空格
[*.swift]
indent_size = 4
max_line_length = 120

# Web 系（设计原型 / 文档示例）2 空格
[*.{html,css,js,json,yaml,yml,toml}]
indent_size = 2

# Markdown：保留行尾两空格的 hard break
[*.md]
indent_size = 2
trim_trailing_whitespace = false
max_line_length = off

# Shell
[*.sh]
indent_size = 2

# Xcode 工程文件保持原样
[*.pbxproj]
indent_style = tab
trim_trailing_whitespace = false

# Makefile 必须 tab
[Makefile]
indent_style = tab
